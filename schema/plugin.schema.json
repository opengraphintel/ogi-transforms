{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/opengraphintel/ogi-transforms/schema/plugin.schema.json",
  "title": "OGI Transform Plugin Manifest",
  "description": "Schema for plugin.yaml files in the OGI transform registry",
  "type": "object",
  "required": [
    "name",
    "version",
    "display_name",
    "description",
    "author",
    "license",
    "category",
    "input_types",
    "output_types",
    "min_ogi_version"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Transform slug: lowercase letters, digits, and hyphens only"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+",
      "description": "Semantic version (e.g., 1.0.0)"
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Human-readable name"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "Short description of what this transform does"
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "description": "Author name"
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier (e.g., AGPL-3.0)"
    },
    "category": {
      "type": "string",
      "enum": [
        "dns",
        "email",
        "web",
        "ip",
        "cert",
        "social",
        "hash",
        "infrastructure",
        "forensics"
      ],
      "description": "Transform category"
    },
    "input_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Person",
          "Domain",
          "IPAddress",
          "EmailAddress",
          "PhoneNumber",
          "Organization",
          "URL",
          "SocialMedia",
          "Hash",
          "Document",
          "Location",
          "ASNumber",
          "Network",
          "MXRecord",
          "NSRecord",
          "Nameserver",
          "SSLCertificate",
          "Subdomain",
          "HTTPHeader"
        ]
      },
      "minItems": 1,
      "description": "Entity types this transform accepts as input"
    },
    "output_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Person",
          "Domain",
          "IPAddress",
          "EmailAddress",
          "PhoneNumber",
          "Organization",
          "URL",
          "SocialMedia",
          "Hash",
          "Document",
          "Location",
          "ASNumber",
          "Network",
          "MXRecord",
          "NSRecord",
          "Nameserver",
          "SSLCertificate",
          "Subdomain",
          "HTTPHeader"
        ]
      },
      "minItems": 1,
      "description": "Entity types this transform produces"
    },
    "min_ogi_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+",
      "description": "Minimum OGI version required"
    },
    "max_ogi_version": {
      "type": [
        "string",
        "null"
      ],
      "description": "Maximum OGI version supported (optional)"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "description": "Searchable tags"
    },
    "author_github": {
      "type": "string",
      "description": "Author's GitHub username"
    },
    "homepage": {
      "type": "string",
      "format": "uri",
      "description": "Project homepage URL"
    },
    "repository": {
      "type": "string",
      "format": "uri",
      "description": "Source code repository URL"
    },
    "icon": {
      "type": "string",
      "description": "Lucide icon name"
    },
    "color": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$",
      "description": "Accent color as hex (e.g., #dc2626)"
    },
    "python_dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Python package dependencies (pip format)"
    },
    "api_keys_required": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "service",
          "description",
          "env_var"
        ],
        "properties": {
          "service": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "env_var": {
            "type": "string",
            "pattern": "^[A-Z_][A-Z0-9_]*$"
          }
        }
      },
      "description": "API keys needed by this transform"
    },
    "transform_settings": {
      "type": "array",
      "description": "Optional typed settings UI schema for this transform",
      "items": {
        "type": "object",
        "required": [
          "name",
          "display_name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$",
            "description": "Internal setting key (snake_case)"
          },
          "display_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "description": {
            "type": "string"
          },
          "required": {
            "type": "boolean",
            "default": false
          },
          "default": {
            "type": "string",
            "default": ""
          },
          "field_type": {
            "type": "string",
            "enum": [
              "string",
              "integer",
              "number",
              "boolean",
              "select",
              "secret"
            ],
            "default": "string"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "min_value": {
            "type": [
              "number",
              "null"
            ]
          },
          "max_value": {
            "type": [
              "number",
              "null"
            ]
          },
          "pattern": {
            "type": "string",
            "description": "Regex for string/secret fields"
          }
        },
        "additionalProperties": false
      }
    },
    "verification_tier": {
      "type": "string",
      "enum": [
        "official",
        "verified",
        "community",
        "experimental"
      ],
      "description": "Verification tier assigned by maintainers"
    },
    "permissions": {
      "type": "object",
      "properties": {
        "network": {
          "type": "boolean",
          "default": false
        },
        "filesystem": {
          "type": "boolean",
          "default": false
        },
        "subprocess": {
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false,
      "description": "Safety permissions"
    },
    "enabled": {
      "type": "boolean",
      "default": true,
      "description": "Whether this transform is enabled by default"
    }
  },
  "additionalProperties": false
}
